# Copie para .env e preencha. O .env NUNCA vai para o Git (está no .gitignore).
# Usado pelo bootstrap.py para configurar o painel numa máquina nova.

# Usuário administrador (ZOPU) que vê todos os ambientes
MASTER_USER=master
MASTER_PASS=troque-esta-senha

# Primeiro ambiente (empresa cliente)
TENANT_NAME=Coontrol
BITRIX_WEBHOOK=https://SEU_PORTAL.bitrix24.com.br/rest/<user>/<token>/
SALES_CATEGORY_ID=16

# Usuário cliente opcional (vê só o ambiente acima). Deixe vazio para pular.
CLIENT_USER=
CLIENT_PASS=
